<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>忍法一覧</title>

<style>
body {
  margin: 0;
  font-family: sans-serif;
  background: #2a2a2a;
  color: #fff;
}

h1 {
  text-align: center;
  padding: 15px;
  margin: 0;
  background: #111;
}

/* 幅制限 */
.container {
  max-width: 1200px;
  margin: auto;
}

.controls {
  padding: 10px;
  text-align: center;
}

input, select {
  padding: 8px;
  margin: 5px;
  border-radius: 6px;
  border: none;
}

/* グリッド（最大3列） */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
  padding: 15px;
}

/* スマホ */
@media (max-width: 768px) {
  .grid {
    grid-template-columns: 1fr;
  }
}

.card {
    padding: 15px;
    border-radius: 10px;
    background: linear-gradient(145deg, #2e2e2e, #1f1f1f);
    border: 1px solid #666;
}

.title {
  font-weight: bold;
  margin-bottom: 5px;
}

.meta {
  font-size: 13px;
  color: #bbb;
  margin-bottom: 8px;
}

.desc {
  font-size: 14px;
  line-height: 1.6;
}
</style>
</head>

<body>

<h1>忍法一覧</h1>

<div class="container">

<div class="controls">
  <input type="text" id="search" placeholder="忍法名で検索">
  <select id="filter">
    <option value="">すべて</option>
    <option value="攻撃">攻撃</option>
    <option value="サポート">サポート</option>
    <option value="装備">装備</option>
  </select>
</div>

<div class="grid" id="grid"></div>

</div>

<script>
const data = [

{
name:"接近戦攻撃（せっきんせんこうげき）",
type:"攻撃",
meta:"間合1 / コストなし",
desc:"接近戦攻撃。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。"
},

{
name:"威光（いこう）",
type:"攻撃",
meta:"間合1 / コスト1 / 指定特技：自由",
desc:"接近戦攻撃。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。もし、目標のプロット値が自分よりも低かった場合、さらに接近戦ダメージを1点与えることができる。"
},

{
name:"怪鳥（けちょう）",
type:"攻撃",
meta:"間合1 / コスト1 / 指定特技：登術",
desc:"接近戦攻撃。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。さらに、同じ対象に対してもう一度攻撃を行うことができる。"
},

{
name:"凸拳（とっけん）",
type:"攻撃",
meta:"間合1 / コストなし / 指定特技：怪力術",
desc:"接近戦攻撃。この攻撃を回避された場合、この忍法によるダメージは発生しない。その代わりに、目標は回避判定に成功した場合でも、接近戦ダメージを1点受ける。"
},

{
name:"交叉（こうさ）",
type:"攻撃",
meta:"間合0 / コスト1 / 指定特技：刀術",
desc:"接近戦攻撃。攻撃が成功すると、目標に接近戦ダメージを2点与えることができる。"
},

{
name:"撫斬（なでぎり）",
type:"攻撃",
meta:"間合1 / コスト1 / 指定特技：刀術",
desc:"接近戦。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。さらに、自分の生命力が最大値より1点以上減っている場合、追加で接近戦ダメージを1点与えることができる。"
},

{
name:"衝手（しょうしゅ）",
type:"攻撃",
meta:"間合1 / コスト1 / 指定特技：拳術",
desc:"接近戦。攻撃が成功すると、目標に接近戦ダメージを1点与え、「よろめき」を与えることができる。"
},

{
name:"天牛（かまきり）",
type:"攻撃",
meta:"間合0 / コスト4 / 指定特技：怪力",
desc:"接近戦。攻撃が成功すると目標に接近戦ダメージを1点与える。目標の持っている装備（特殊忍具を含む）を一つ失わせることができる（どの装備を失うかは攻撃された側が決定する）。"
},

{
name:"影縫（かげぬい）",
type:"攻撃",
meta:"間合1 / コストなし / 指定特技：潜伏術",
desc:"接近戦。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。さらに、自分が隠れていた場合、追加で接近戦ダメージを1点与えることができる。"
},

{
name:"毒手（どくしゅ）",
type:"攻撃",
meta:"間合0 / コスト1 / 指定特技：毒術",
desc:"接近戦。攻撃が成功すると、目標に接近戦ダメージを1点と「マヒ」の変調を与えることができる。"
},

{
name:"砂縛（さばく）",
type:"攻撃",
meta:"間合2 / コスト4 / 指定特技：異形術",
desc:"近距離。戦闘開始時に自分よりプロット値が低いキャラクターを目標に選ぶ。目標に接近戦ダメージを1点与えることができる。この忍法の命中判定に成功した場合、目標は回避判定を行う。失敗すると、目標は接近戦ダメージを1点受ける。"
},

{
name:"飛魂（ひこん）",
type:"攻撃",
meta:"間合3 / コスト1 / 指定特技：変装術",
desc:"接近戦。この忍法は、自分の追加のものではない命中が1点以上失われていないと使用できない。攻撃が成功すると、目標に接近戦ダメージを1点与えることができる。"
}

];

const grid = document.getElementById("grid");

function render() {
  const search = document.getElementById("search").value;
  const filter = document.getElementById("filter").value;

  grid.innerHTML = "";

  data
    .filter(d => d.name.includes(search))
    .filter(d => !filter || d.type === filter)
    .forEach(d => {
      const card = document.createElement("div");
      card.className = "card";
      card.innerHTML = `
        <div class="title">${d.name}</div>
        <div class="meta">${d.type} / ${d.meta}</div>
        <div class="desc">${d.desc}</div>
      `;
      grid.appendChild(card);
    });
}

document.getElementById("search").addEventListener("input", render);
document.getElementById("filter").addEventListener("change", render);

render();
</script>

</body>
</html>
